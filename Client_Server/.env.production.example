APP_NAME=FT-IR Client Server
APP_ENV=production
API_PREFIX=/api/v1

# MySQL
MYSQL_ROOT_PASSWORD=REPLACE_WITH_GENERATED_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=ftir
MYSQL_USER=ftir
MYSQL_PASSWORD=REPLACE_WITH_GENERATED_MYSQL_APP_PASSWORD

# JWT authentication
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
JWT_PREVIOUS_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_CURRENT_KID=v1
JWT_PREVIOUS_KID=

# Bootstrap admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_GENERATED_ADMIN_PASSWORD

# Storage backend
STORAGE_BACKEND=local

# NAS / shared storage for Docker CIFS volume
NAS_HOST=192.168.1.77
NAS_SHARE=zhaozhixuan/shared_storage
NAS_USER=REPLACE_WITH_NAS_USER
NAS_PASS=REPLACE_WITH_NAS_PASSWORD
NAS_VERS=3.0

# Optional external API keys
DASHSCOPE_API_KEY=
OPENROUTER_API_KEY=
CAS_API_KEY=
SERP_API_KEY=

# Notes:
# 1. Place real values in Client_Server/.env or another untracked env file.
# 2. Keep worker-side backend/.env JWT_* values aligned with the API.
# 3. If you later rotate JWT keys, fill JWT_PREVIOUS_SECRET_KEY and JWT_PREVIOUS_KID temporarily.
# 4. STORAGE_BACKEND=local means the mounted /shared path is treated as a normal local filesystem path.
# 5. Remote Windows workers still need their own backend/.env with reachable DATABASE_URL/CELERY_* hosts.